{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "idea-lab",
  "main": "src/index.js",
  "compatibility_date": "2026-05-28",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    { "binding": "SIGNUPS", "id": "bfa1c4a85b7b4a79bc790bdffd92eead" }
  ],
  "observability": {
    "enabled": true
  }
}
